// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // directUrl = env("DIRECT_DATABASE_URL")
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(cuid())
  username  String  @unique
  email     String? @unique
  privyId   String? @unique
  phantomId String? @unique
  solanaWallet   String?
  ethereumWallet String?
  points    Int     @default(0)

  // TEMP: make it optional and remove @unique for first push
  referralCode String? @unique
  referredBy   String? // FK to User.id

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginDate DateTime?

  lastReportDate DateTime?
  reportsToday   Int       @default(0)
  lastQueryDate  DateTime?
  queriesToday   Int       @default(0)

  // Subscription & usage tracking
  subscriptionPlan        SubscriptionPlan @default(FREE)
  subscriptionPeriodStart DateTime?
  subscriptionPeriodEnd   DateTime?

  // Monthly paid bundle usage (for active CLAW_PRO periods)
  clawMessagesThisPeriod             Int @default(0)
  rexScreenerReportsThisPeriod       Int @default(0)
  rexScreenerFollowupsThisPeriod     Int @default(0)
  rexMarketsReportsThisPeriod        Int @default(0)
  rexMarketsTechFollowupsThisPeriod  Int @default(0)
  rexMarketsNewsFollowupsThisPeriod  Int @default(0)

  // Free Tier daily usage (resets every day)
  freeTierUsageDate                  DateTime?
  clawFreeMessagesToday              Int @default(0)
  rexScreenerFreeReportsToday        Int @default(0)
  rexMarketsFreeTechReportsToday     Int @default(0)
  rexMarketsFreeNewsReportsToday     Int @default(0)

  // BNB daily mission (resets every day)
  bnbWalletConnected    Boolean   @default(false)
  bnbSignatureCompleted Boolean   @default(false)
  bnbMissionCompleted   Boolean   @default(false)
  lastBnbMissionDate    DateTime?

  reports   Report[]
  swaps     SwapTransaction[]
  clawV5Chats ClawV5Chat[]
  referrer  User?    @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals User[]   @relation("UserReferrals")
  polymarketTrades PolymarketTrade[]
  subscriptions Subscription[]

  @@map("users")
}

enum SubscriptionPlan {
  FREE
  CLAW_PRO
}

/// User subscription history (MoonPay): one row per subscribe/renew event.
model Subscription {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId String?  // MoonPay/Helio transaction id
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([transactionId])
  @@map("Subscription")
}

// Polymarket prediction market trade – one row per filled trade for dashboard volume (total, per week, per user).
// Synced from client when user loads Polymarket UI or after placing an order (useTrades data).
model PolymarketTrade {
  id               String   @id @default(cuid())
  polymarketTradeId  String   @unique // External ID from Polymarket to avoid duplicates
  walletAddress    String   // Ethereum address (maker or taker)
  userId          String?  // Linked RaptorX user (matched by ethereumWallet)
  user            User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  volumeUsd       Float    // size * price (USD notional per trade)
  tradedAt        DateTime // match_time from Polymarket
  createdAt      DateTime @default(now())

  @@index([walletAddress])
  @@index([userId])
  @@index([tradedAt])
  @@map("polymarket_trades")
}

model Report {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contractAddress String
  ticker          String
  projectName     String?
  chain           String   @default("solana") // "solana" | "bnb"
  reportType      String   @default("crypto") // "crypto" | "market"
  content         String
  dexData         Json? // store Dexscreener payload
  tweetsData      Json? // store parsed tweets data
  securityData    Json? // store security analytics data for BNB tokens
  holdersData     Json? // store holder analytics data for BNB tokens
  marketData      Json? // store market-specific data for prediction markets
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 1:1 conversation (unique reportId on Conversation)
  conversation Conversation?

  @@index([userId])
  @@index([userId, chain])
  @@index([userId, reportType])
  @@index([contractAddress, chain])
  @@map("reports")
}

model Conversation {
  id        String    @id @default(cuid())
  reportId  String    @unique
  report    Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("conversations")
}

enum MessageRole {
  user
  assistant
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  timestamp      DateTime     @default(now())
  /// For market reports: "tech" | "news" to enforce 2 tech + 2 news queries per report per day (free tier).
  followupKind   String?

  @@index([conversationId])
  @@map("messages")
}

model SystemReport {
  id              String   @id @default(cuid())
  contractAddress String
  ticker          String
  projectName     String?
  chain           String   @default("solana") // "solana" | "bnb"
  content         String
  dexData         Json?
  tweetsData      Json? // store parsed tweets data
  securityData    Json? // store security analytics data for BNB tokens
  holdersData     Json? // store holder analytics data for BNB tokens
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([contractAddress, ticker, chain])
  @@index([chain])
  @@map("systemreports")
}

/// Golden Report program: curated contracts whose teams may publish "Team Updates" (shown in RexScreener before What It Is).
/// Rows are created/updated from the RaptorX internal metrics dashboard via `/api/internal/golden-reports/projects` (shared secret).
/// Same table holds Pump Reports listings: `isGolden` true = Golden (default); false = Pump.
model GoldenReportProject {
  id                     String    @id @default(cuid())
  contractAddress        String
  chain                  String    @default("solana")
  /// true = Golden Reports tier (default); false = Pump Reports tier.
  isGolden               Boolean   @default(true)
  /// RaptorX user emails allowed to publish updates (must match `User.email` at login). Set from internal dashboard.
  authorizedEditorEmails String[]  @default([])
  teamUpdatesContent     String    @default("")
  teamUpdatesPublishedAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([contractAddress, chain])
  @@index([chain])
  @@index([isGolden])
  @@map("golden_report_projects")
}

model SwapTransaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountUSD       Float
  fromToken       String
  toToken         String
  fromAddress     String   // token contract address (from)
  toAddress       String   // token contract address (to)
  chain           String   // "solana" | "bnb"
  isBuy           Boolean  // true for buy, false for sell
  pointsAwarded   Int      @default(0)
  // LiFi tracking fields
  walletAddress   String?  // wallet that performed the swap (proof of purchase)
  fromAmountRaw   String?  // raw token amount spent (e.g. SOL/USDC)
  toAmountRaw     String?  // raw token amount received (coins purchased)
  txHash          String?  // transaction hash for proof of purchase
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([userId, chain])
  @@index([txHash])
  @@map("swaptransactions")
}

model ClawV5Chat {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  messages  ClawV5Message[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
  @@map("clawv5chats")
}

enum ClawV5MessageRole {
  user
  assistant
}

model ClawV5Message {
  id        String          @id @default(cuid())
  chatId    String
  chat      ClawV5Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      ClawV5MessageRole
  content   String
  createdAt DateTime        @default(now())

  @@index([chatId])
  @@map("clawv5messages")
}